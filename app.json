{
  "expo": {
    "name": "Argon",
    "slug": "client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/components-logo/Logotype-1024.png",
    "scheme": "argon",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.argon.messenger"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/components-logo/Logotype-512.png",
        "backgroundColor": "#8b5cf6"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.argon.messenger",
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResources": true,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/components-logo/Logotype-512.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/components-logo/Logotype-1024.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "751d38cd-7138-4ed4-ac8a-2ccd2aa3875d"
      },
      "router": {}
    }
  }
}